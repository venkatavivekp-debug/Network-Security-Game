# Database
DB_NAME=network_security_game
DB_PASSWORD=root
DB_PORT=3306

# App
APP_PORT=8080

# Crypto (required for Docker Compose `SPRING_PROFILES_ACTIVE=docker`)
# Generate two independent 32-byte keys, base64-encoded, e.g.:
#   openssl rand -base64 32
APP_CRYPTO_MASTER_KEY=REPLACE_ME_BASE64_32_BYTES
APP_CRYPTO_SHCS_KEY=REPLACE_ME_BASE64_32_BYTES_DIFFERENT_FROM_MASTER

# Optional demo seeding
APP_SEED_DEMO_DATA=true
APP_DEMO_SENDER_USERNAME=demo_sender
APP_DEMO_SENDER_PASSWORD=DemoSender#123
APP_DEMO_RECEIVER_USERNAME=demo_receiver
APP_DEMO_RECEIVER_PASSWORD=DemoReceiver#123

# Optional local run vars (non-docker)
# DB_URL=jdbc:mysql://localhost:3306/network_security_game?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
# DB_USERNAME=root
# SERVER_PORT=8080

# Optional advanced simulation tuning
# APP_ADV_NORMAL_COMPROMISE_MULTIPLIER=1.0
# APP_ADV_SHCS_COMPROMISE_MULTIPLIER=0.84
# APP_ADV_CPHS_COMPROMISE_MULTIPLIER=0.68
